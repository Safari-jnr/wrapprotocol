# ─── Mork Airdrop — Environment Variables ────────────────────────────────────
# Copy this to .env.local and fill in values.
# Safari holds all secrets. Share only NEXT_PUBLIC_* keys with Mide.

# ─── Supabase (Safari manages — share only anon key with Mide) ───────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...           # safe to share with Mide
SUPABASE_SERVICE_ROLE_KEY=eyJ...               # NEVER share — server only

# ─── WalletConnect ────────────────────────────────────────────────────────────
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=          # get from cloud.walletconnect.com

# ─── EVM Contract ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_EVM_CHAIN=sepolia                  # mainnet | base | sepolia
NEXT_PUBLIC_EVM_CONTRACT_ADDRESS=0x0000...     # fill after deploy
NEXT_PUBLIC_MORK_TOKEN_ADDRESS=0x0000...       # fill after deploy
EVM_RPC_URL=https://rpc.sepolia.org            # private RPC recommended (Alchemy/Infura)
EVM_PRICE_ETH=0.01                             # for indexer use

# ─── Treasury (contracts/evm/.env only — never here) ─────────────────────────
# The treasury address receives all user payments. You can reuse the deployer
# wallet: run `cast wallet address --private-key $PRIVATE_KEY` to get its address.

# ─── Solana ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SOLANA_NETWORK=devnet              # mainnet-beta | devnet
NEXT_PUBLIC_SOLANA_PROGRAM_ID=11111...         # fill after anchor deploy
NEXT_PUBLIC_SOLANA_RPC_URL=                    # optional — overrides clusterApiUrl
NEXT_PUBLIC_MORK_TOKEN_MINT_SOLANA=11111...    # SPL token mint address (fill after deploy)

# ─── Claim parameters ─────────────────────────────────────────────────────────
# Pricing: 30% of wallet balance, clamped to [EVM_MIN_PRICE, EVM_MAX_PRICE]
# These are used by the indexer — the frontend computes dynamically from balance
TOKENS_PER_CLAIM=1000
EVM_MIN_PRICE_ETH=0.001
EVM_MAX_PRICE_ETH=1.0

# ─── Resend (feedback emails) ────────────────────────────────────────────────
# Get API key from resend.com — free tier is 3000 emails/month
RESEND_API_KEY=re_...
FEEDBACK_FROM_EMAIL=feedback@yourdomain.com   # must be verified in Resend
FEEDBACK_TO_EMAIL=your@email.com              # where feedback lands
