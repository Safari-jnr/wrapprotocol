# ─── Foundry / EVM deployment env vars — Base Mainnet ────────────────────────
# Copy to contracts/evm/.env and fill in. Never commit .env.

# Your deployer wallet private key (without 0x prefix)
# This wallet needs ETH on Base — get ~$1 worth of ETH bridged to Base
PRIVATE_KEY=your_private_key_here

# Base mainnet RPC — public endpoint is fine for deploy
# For production indexer use Alchemy/QuickNode: https://www.alchemy.com/base
BASE_RPC_URL=https://mainnet.base.org

# Basescan API key — optional, only needed for contract verification
# Get from: https://basescan.org → sign up → API Keys
# Skip this for now — you can verify contracts later
# ETHERSCAN_API_KEY=your_basescan_key_here

# ─── DeployAirdrop only (fill after deploying MorkToken) ─────────────────────
MORK_TOKEN=0x...          # MorkToken address after deploy
TREASURY=0x15b07714d81d97CF1dcbD9678D07DFC545b97E38
